# ========================================
# 其他配置
# ========================================

# AI 温度（0.0 - 2.0，越高越随机）
AI_TEMPERATURE=0.7

# 最大 Token 数
AI_MAX_TOKENS=2000

# 是否启用流式响应
STREAM_ENABLED=true

# 是否启用工具系统（Agent 模式）
# true - 启用工具系统，AI 可以调用工具（如搜索文件、执行命令等）
# false - 禁用工具系统，使用普通对话模式
TOOLS_ENABLED=true